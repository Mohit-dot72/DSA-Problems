class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        int n = nums.size();
        unordered_map<int,int> um;
        for(int i=0;i<n;i++){
            int a = nums[i];
            int b = target - nums[i];

            if(um.find(b) != um.end()){
                return {um[b],i};
            }
            um[a] = i;
        }
        return {};
    }
};
